# =============================================================================
# THRONOS V3.6 — MAIN CORE NODE — ENVIRONMENT VARIABLES REFERENCE
#
# ⚠️  PRODUCTION DEPLOYMENT:
# - Do NOT commit .env to git
# - Set all values via Railway Variables dashboard
# - See: https://docs.railway.app/reference/variables
# - This file serves as a template for development only
# =============================================================================

# ---------------------------------------------------------------------------
# APP / NODE
# ---------------------------------------------------------------------------
APP_ENV=production
APP_VERSION=v3.6
NODE_ROLE=master
IS_LEADER=1
READ_ONLY=0
SCHEDULER_ENABLED=1

# ---------------------------------------------------------------------------
# LLM PROVIDERS (set in Railway Variables, never in git)
# ---------------------------------------------------------------------------
# Set exactly ONE primary; the rest are fallback.
# THRONOS_AI_MODE=anthropic
# ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY
# OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY
# GEMINI_API_KEY=REPLACE_WITH_YOUR_KEY
AI_CORE_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# INTERNAL AUTH KEY (set in Railway Variables)
# Every service calling /api/chat, /api/ai/*, /tx/* must send this
# in X-Internal-Key or X-API-Key header.
# ---------------------------------------------------------------------------
# APP_AI_KEY=REPLACE_WITH_YOUR_KEY (Railway Variable only)

# ---------------------------------------------------------------------------
# ADMIN & SECRETS (set in Railway Variables)
# ---------------------------------------------------------------------------
# ADMIN_SECRET=REPLACE_WITH_YOUR_KEY (Railway Variable only)
# AI_LOG_API_KEY=REPLACE_WITH_YOUR_KEY (Railway Variable only)
# APP_SECRET_KEY=REPLACE_WITH_YOUR_KEY (Railway Variable only)
# X9_VOICE_WEBHOOK_SECRET=REPLACE_WITH_YOUR_KEY (Railway Variable only)

# ---------------------------------------------------------------------------
# URLS — update after Railway assigns your domain
# ---------------------------------------------------------------------------
MASTER_URL=https://thronos-core.up.railway.app
MASTER_PUBLIC_URL=https://thronos-core.up.railway.app
PUBLIC_URL=https://api.thronoschain.org
BOOTSTRAP_PRIMARY=https://api.thronoschain.org
BOOTSTRAP_READONLY=https://node2.thronoschain.org
BOOTSTRAP_EXPLORER=https://explorer.thronoschain.org
BOOTSTRAP_VERIFYID=https://verifyid.thronoschain.org
BOOTSTRAP_VERIFYID_API=https://api.thronoschain.org/api/verifyid
BOOTSTRAP_AI_CORE=https://ai.thronoschain.org
BOOTSTRAP_SENTINEL=https://sentinel.thronoschain.org
BOOTSTRAP_BTC_API=https://btc-api.thronoschain.org
AI_CORE_URL=https://thronos-core.up.railway.app

# ---------------------------------------------------------------------------
# REDIS (set in Railway Variables)
# Railway Redis plugin will set REDIS_URL automatically
# ---------------------------------------------------------------------------
REDIS_CACHE_ENABLED=1
# REDIS_URL=redis://default:REPLACE_WITH_RAILWAY_REDIS_URL@redis.railway.internal:6379

# ---------------------------------------------------------------------------
# DATABASE (set in Railway Variables)
# SQLite for development; PostgreSQL plugin for production
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///data/thronos.db
USE_SQLITE_LEDGER=1
# For production: use Railway Postgres plugin and set DATABASE_URL via Variables

# ---------------------------------------------------------------------------
# DATA STORAGE
# ---------------------------------------------------------------------------
DATA_DIR=/app/data
MUSIC_VOLUME=/app/data

# ---------------------------------------------------------------------------
# BTC CONFIG (mainnet addresses are public; set keys in Railway Variables)
# ---------------------------------------------------------------------------
BTC_PLEDGE_VAULT=1QFeDPwEF8yEgPEfP79hpc8pHytXMz9oEQ
BTC_HOT_WALLET=1QFeDPwEF8yEgPEfP79hpc8pHytXMz9oEQ
BTC_TREASURY=3KUGVJQ5tJWKY7GDVgwLjJ7EBzVWatD9nF
BTC_NETWORK_FEE=0.0002
MIN_BTC_WITHDRAWAL=0.001
MAX_BTC_WITHDRAWAL=0.5
WITHDRAWAL_FEE_PERCENT=0.5
THR_BTC_RATE=33333.33

# Cross-chain withdrawal fee policy (#695 Phase 2.2)
# Protocol fee charged on withdrawal amount (percent)
CROSSCHAIN_PROTOCOL_FEE_PERCENT=0.5
# Fixed gas cost estimate in USD (charged separately from protocol fee)
CROSSCHAIN_GAS_FEE_USD=2.0
# Minimum withdrawal amounts
MIN_USDT_WITHDRAWAL=10.0
MIN_USDC_WITHDRAWAL=10.0
# Withdrawal fee mode (phase 2)
# HYBRID = protocol_fee_thr + small external_service_fee in token (default)
# THR_ONLY = THR fee only, no external token fee
# EXTERNAL_TOKEN_ONLY = no THR fee, external token fee only
WITHDRAWAL_FEE_MODE=HYBRID
# Anti-rug: max fraction of pool reserve available for a single withdrawal (0.90 = 90%)
WITHDRAWAL_MAX_POOL_FRACTION=0.90

# THR address that accumulates THR-denominated protocol fees (Thronos chain only)
# FEE_COLLECTOR_THR_ADDRESS=THR...  (set in Railway Variables)

# Per-chain withdrawal infrastructure (BSC, BASE, Arbitrum, Ethereum)
# Each chain has 4 role-specific wallet addresses set via Railway Variables:
#
# <CHAIN>_PAYOUT_ADDRESS (formerly <CHAIN>_HOT_WALLET)
#   - Sends cross-chain withdrawal transactions to external chains
#   - Requires sufficient gas/native coin reserve for transaction fees
#   - Fallback: uses <CHAIN>_HOT_WALLET if <CHAIN>_PAYOUT_ADDRESS not set
#
# <CHAIN>_POOL_VAULT_ADDRESS
#   - Receives USDT/USDC deposits from LP contributors (liquidity provision)
#   - Separate from payout_wallet; never receives user withdrawals
#   - Fallback: uses PYTHIA_SYSTEM_EVM_<CHAIN>_ADDRESS if not explicitly set
#
# <CHAIN>_FEE_COLLECTOR_ADDRESS
#   - Accumulates external-service fee (external_token_only) during withdrawals
#   - Receives ~87.5% of the gas_fee_usd_estimate (external fee split logic)
#   - Example: $2.00 gas fee → $1.75 to fee_collector + $0.25 pool top-up reserve
#
# <CHAIN>_GAS_WALLET_ADDRESS (optional)
#   - Dedicated wallet for replenishing gas/native coin reserves
#   - Never used as a token vault (pledge/pool/withdrawal destination)
#   - Exclusively for operational gas management

# ─── BSC (BNB Chain) Withdrawal Addresses ───
# BSC_PAYOUT_ADDRESS=0x...          (set in Railway Variables; fallback: BNB_HOT_WALLET)
# BSC_POOL_VAULT_ADDRESS=0x...      (set in Railway Variables)
# BSC_FEE_COLLECTOR_ADDRESS=0x...   (set in Railway Variables)
# BSC_GAS_WALLET_ADDRESS=0x...      (set in Railway Variables; optional)

# ─── BASE (Coinbase Layer 2) Withdrawal Addresses ───
# BASE_PAYOUT_ADDRESS=0x...         (set in Railway Variables; fallback: BASE_HOT_WALLET)
# BASE_POOL_VAULT_ADDRESS=0x...     (set in Railway Variables)
# BASE_FEE_COLLECTOR_ADDRESS=0x...  (set in Railway Variables)
# BASE_GAS_WALLET_ADDRESS=0x...     (set in Railway Variables; optional)

# ─── Arbitrum Withdrawal Addresses ───
# ARB_PAYOUT_ADDRESS=0x...          (set in Railway Variables; fallback: ARB_HOT_WALLET)
# ARB_POOL_VAULT_ADDRESS=0x...      (set in Railway Variables)
# ARB_FEE_COLLECTOR_ADDRESS=0x...   (set in Railway Variables)
# ARB_GAS_WALLET_ADDRESS=0x...      (set in Railway Variables; optional)

# ─── Ethereum Withdrawal Addresses ───
# ETH_PAYOUT_ADDRESS=0x...          (set in Railway Variables; fallback: ETH_HOT_WALLET)
# ETH_POOL_VAULT_ADDRESS=0x...      (set in Railway Variables)
# ETH_FEE_COLLECTOR_ADDRESS=0x...   (set in Railway Variables)
# ETH_GAS_WALLET_ADDRESS=0x...      (set in Railway Variables; optional)

# BTC RPC configuration (optional; leave blank to use public API)
# BTC_RPC_URL=      (set in Railway Variables if needed)
# BTC_RPC_USER=     (set in Railway Variables)
# BTC_RPC_PASSWORD= (set in Railway Variables)

# ---------------------------------------------------------------------------
# EVM RPC ENDPOINTS (public endpoints — no auth needed)
# ---------------------------------------------------------------------------
ETH_RPC_URL=https://eth.llamarpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
XRP_RPC_URL=https://xrplcluster.com

# ---------------------------------------------------------------------------
# STRIPE (keys in Railway Variables only)
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=      # set in Railway Variables
# STRIPE_PUBLISHABLE_KEY= # set in Railway Variables
# STRIPE_WEBHOOK_SECRET=  # set in Railway Variables
DOMAIN_URL=https://api.thronoschain.org

# ---------------------------------------------------------------------------
# WALLET V1 — Signing, Migration & Cryptography
# Public/config values only; all key material in Railway Variables
# ---------------------------------------------------------------------------

# Verified migration addresses (hardcoded per security audit)
# These are the canonical addresses for wallet v1 migration precedence.
WALLET_V1_VERIFIED_LEGACY_SOURCE=THR79ca94a7eb70a6aa99d12d7fdb01446ef246301a
WALLET_V1_VERIFIED_CANONICAL=THR683318ACF083723B3EDFE6C0A30AD62670F00353

# System wallets to reject during user address persistence
# These are reserved system wallets that users cannot manually unlock/persist.
WALLET_SYSTEM_ADDRESSES=THR5DF27A86C477F381594E896F0E55357DEC5942BA,THR_AI_AGENT_WALLET_V1

# Pythia/System signer wallet — Thronos + public EVM addresses.
# The THR address is the same as THR_AI_AGENT_WALLET unless overridden.
# The EVM addresses are the public on-chain addresses the system signer controls.
# BSC_POOL_VAULT_ADDRESS takes priority; PYTHIA_SYSTEM_EVM_BSC_ADDRESS is the MVP fallback.
# NEVER put private keys, seeds, or mnemonics here.
THR_AI_AGENT_WALLET=THR5DF27A86C477F381594E896F0E55357DEC5942BA
PYTHIA_SYSTEM_THR_ADDRESS=THR5DF27A86C477F381594E896F0E55357DEC5942BA
PYTHIA_SYSTEM_EVM_BSC_ADDRESS=
PYTHIA_SYSTEM_EVM_BASE_ADDRESS=
PYTHIA_SYSTEM_EVM_ARBITRUM_ADDRESS=
PYTHIA_SYSTEM_EVM_ETHEREUM_ADDRESS=

# Pool vault addresses (preferred — chain-specific vault the system signer controls)
# If not set, falls back to PYTHIA_SYSTEM_EVM_*_ADDRESS above.
BSC_POOL_VAULT_ADDRESS=
BASE_POOL_VAULT_ADDRESS=
ARB_POOL_VAULT_ADDRESS=

# ── Pool deposit watcher ─────────────────────────────────────────────────────
# Enable real on-chain scanning for pool deposits. Requires:
#   BSC_RPC_URL, BSC_POOL_VAULT_ADDRESS (or PYTHIA_SYSTEM_EVM_BSC_ADDRESS),
#   BSC_USDT_CONTRACT — same for BASE and ARB.
# Watcher scans vault-address transfer logs, matches to pending
# pool_deposit_intents, and credits LP shares to depositor addresses.
POOL_WATCHER_ENABLED=0

# ── Test/staging only: mock pool liquidity credit (bypasses on-chain proof) ──
# Must remain 0 in production. When 0, /api/admin/pools/{bsc-usdt,base-usdc}/
# credit-test-liquidity returns 403 pool_test_mode_disabled. Real liquidity
# always flows through /api/admin/pools/watcher/credit-external-deposit
# after on-chain confirmation.
POOL_TEST_MODE=0

# ERC20/BEP20 contracts for pool assets
BSC_USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
BASE_USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Pledge vault (keep SEPARATE from pool vault)
BSC_USDT_PLEDGE_VAULT=

# Cryptographic signing helpers (secp256k1, HMAC-SHA256, DER format support)
WALLET_V1_CRYPTO_MODE=async
WALLET_V1_SECP256K1_PROVIDER=noble
WALLET_V1_HMAC_SHA256_ENABLED=1
WALLET_V1_DER_SIGNATURE_FORMAT=enabled

# Swap signature verification (canonical payload format)
SWAP_SIGNATURE_VERIFICATION_ENABLED=1
SWAP_CANONICAL_PAYLOAD_FORMAT=json
SWAP_SUPPORTED_ACTIONS=swap,execute_swap,token_swap,swap_tokens

# Wallet unlock & session settings (fixed security parameters)
WALLET_V1_PIN_ITERATIONS=250000
WALLET_V1_AES_GCM_ENABLED=1
WALLET_V1_RUNTIME_SIGNING_ENABLED=1
WALLET_V1_AUTO_LOCK_ON_MISMATCH=1

# ---------------------------------------------------------------------------
# MINING / STRATUM
# ---------------------------------------------------------------------------
STRATUM_PORT=3334
ENABLE_MICRO_MINER=false
MINING_WHITELIST_ONLY=0
MINING_WATCHDOG_WINDOW_SECONDS=60
MINING_WATCHDOG_MAX_INVALID=12
MINING_WATCHDOG_MAX_REQUESTS=60
MINING_WATCHDOG_BAN_SECONDS=300

# ---------------------------------------------------------------------------
# PYTHEIA MONITORING
# ---------------------------------------------------------------------------
PYTHEIA_STANDALONE=false
HEARTBEAT_ENABLED=1
HEARTBEAT_LOG_ERRORS=0

# ---------------------------------------------------------------------------
# AI FEATURES
# ---------------------------------------------------------------------------
AI_FREE_MESSAGES_LIMIT=5
GUEST_MAX_FREE_MESSAGES=5
GUEST_MAX_FREE_SESSIONS=1
GUEST_TTL_SECONDS=604800
MUSIC_MODAL_ENABLED=1
THR_OFFLINE_CORPUS_ENABLED=false
THR_THAI_ENABLED=false
ARCHITECT_T2E_REWARD_CREDITS=0

# ---------------------------------------------------------------------------
# ASSET CDN
# ---------------------------------------------------------------------------
ASSET_CDN_BASE=https://thrchain.vercel.app

# ---------------------------------------------------------------------------
# EduPresence Integration
# Set these in the EduPresence service on Railway:
# THRONOS_ATTEST_URL   = https://api.thronoschain.org/api/attest (Railway Variable)
# THRONOS_ATTEST_API_KEY = same as APP_AI_KEY above (Railway Variable)
# ---------------------------------------------------------------------------

