# Thronos Miner — sample environment configuration
# Copy this file, fill in your values, and source it before running the miner.
#
# Linux/macOS:  source sample_wallet.env
# Windows:      set commands must be run individually or via run_*.bat scripts

# ── Required ─────────────────────────────────────────────────────────────────
THR_ADDRESS=THR_PUT_YOUR_ADDRESS_HERE
THRONOS_API_URL=https://api.thronoschain.org

# ── Optional ──────────────────────────────────────────────────────────────────
MINER_NAME=my-miner
STRATUM_PORT=3334
THRONOS_SUBMIT_RETRIES=3
THRONOS_SUBMIT_RETRY_DELAY=2

# DO NOT put private keys, seeds, or mnemonics here.
# Mining uses your public address only.
